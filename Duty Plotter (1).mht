<body>
  <div class="wrap">
    <div class="topbar">
      <div>
        <h1>Intern Duty Plotter</h1>
        <div class="sub">A prototype self-plotting page for make-up duties. Users choose a date, shift, and laboratory section, then claim one available slot. Each section shows remaining capacity visually, including the new overnight duty option.</div>
      </div>
      <button class="theme-btn" id="themeToggle" aria-label="Toggle theme">Toggle theme</button>
    </div>

    <div class="panel-grid">
      <aside class="panel">
        <h2>Your booking</h2>
        <div class="field">
          <label for="internName">Full name</label>
          <input id="internName" placeholder="Enter your full name">
        </div>
        <div class="field">
          <label for="internEmail">Email</label>
          <input id="internEmail" type="email" placeholder="name@example.com">
        </div>
        <div class="field">
          <label for="internGroup">Group</label>
          <select id="internGroup">
            <option value="">Select group</option>
            <option>A</option><option>B</option><option>C</option><option>D</option><option>E</option><option>F</option><option>G</option>
          </select>
        </div>
        <div class="notice">Prototype rule: one person can hold one slot at a time. Clicking another available slot reassigns that same person.</div>

        <div class="inline-actions" style="margin-top:1rem;">
          <button class="primary-btn" id="clearMine">Clear my booking</button>
          <button class="ghost-btn" id="seedDemo">Load demo data</button>
        </div>

        <div style="margin-top:1.5rem;">
          <h2>Legend</h2>
          <div class="legend">
            <div class="legend-item"><span class="dot" style="background:#437a22"></span>Available</div>
            <div class="legend-item"><span class="dot" style="background:#d19900"></span>Limited</div>
            <div class="legend-item"><span class="dot" style="background:#a12c7b"></span>Full</div>
            <div class="legend-item"><span class="dot" style="background:#01696f"></span>Your booking</div>
          </div>
        </div>

        <div style="margin-top:1.5rem;">
          <h2>Section limits</h2>
          <div class="stats">
            <div class="stat"><strong style="min-width:110px; color:var(--color-text);">Preanalytic</strong><span>3 slots per shift</span></div>
            <div class="stat"><strong style="min-width:110px; color:var(--color-text);">Microbiology</strong><span>3 slots per shift</span></div>
            <div class="stat"><strong style="min-width:110px; color:var(--color-text);">Blood Bank</strong><span>3 slots per shift</span></div>
            <div class="stat"><strong style="min-width:110px; color:var(--color-text);">Others</strong><span>2 slots per shift</span></div>
          </div>
        </div>
      </aside>

      <main>
        <div class="content-head">
          <div>
            <h2 style="margin:0 0 .35rem;">Available slots</h2>
            <div class="sub">Select a date, then choose from day or overnight duty slots. Full sections are locked automatically in this prototype.</div>
          </div>
          <div class="day-tabs" id="dayTabs"><button class="day-tab active">Jun 14</button><button class="day-tab">Jun 15</button><button class="day-tab">Jun 16</button><button class="day-tab">Jun 17</button><button class="day-tab">Jun 18</button></div>
        </div>

        <div class="shift-grid" id="shiftGrid"><section class="shift-card"><h3>6:00 AM–12:00 PM</h3><p>Jun 14 · 0/19 slots filled</p><div class="slot-list"><button class="slot-btn"><div class="slot-meta"><strong>Preanalytic</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Microbiology</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Blood Bank</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Clinical Microscopy</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Clinical Chemistry</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Serology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Hematology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Histopathology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button></div></section><section class="shift-card"><h3>12:00 PM–6:00 PM</h3><p>Jun 14 · 0/19 slots filled</p><div class="slot-list"><button class="slot-btn"><div class="slot-meta"><strong>Preanalytic</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Microbiology</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Blood Bank</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Clinical Microscopy</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Clinical Chemistry</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Serology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Hematology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Histopathology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button></div></section><section class="shift-card"><h3>3:00 PM/7:00 PM–7:00 AM</h3><p>Jun 14 · 0/19 slots filled</p><div class="slot-list"><button class="slot-btn"><div class="slot-meta"><strong>Preanalytic</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Microbiology</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Blood Bank</strong><span>0/3 occupied</span></div><span class="pill available">3 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Clinical Microscopy</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Clinical Chemistry</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Serology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Hematology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button><button class="slot-btn"><div class="slot-meta"><strong>Histopathology</strong><span>0/2 occupied</span></div><span class="pill available">2 left</span></button></div></section></div>

        <div class="panel table-wrap">
          <h2>Current bookings</h2>
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Group</th>
                <th>Date</th>
                <th>Shift</th>
                <th>Section</th>
              </tr>
            </thead>
            <tbody id="bookingRows"><tr><td colspan="5" class="empty">No bookings yet.</td></tr></tbody>
          </table>
        </div>
      </main>
    </div>
  </div>

  


</body></html>
