  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Duty Plotter</title>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&amp;display=swap" rel="stylesheet">
  
