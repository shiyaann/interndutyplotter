* { box-sizing: border-box; }

body { margin: 0px; min-height: 100vh; font-family: var(--font-body); font-size: var(--text-base); line-height: 1.5; color: var(--color-text); background: linear-gradient(180deg, var(--color-bg), var(--color-surface)); }

.wrap { max-width: 1200px; margin: 0px auto; padding: var(--space-6); }

.topbar { display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); margin-bottom: var(--space-6); }

h1 { font-size: var(--text-xl); line-height: 1.1; margin: 0 0 var(--space-2); }

.sub { color: var(--color-text-muted); max-width: 70ch; }

.theme-btn, .primary-btn, .ghost-btn, .slot-btn, select, input { border: 1px solid rgba(0, 0, 0, 0.08); border-radius: var(--radius-md); font: inherit; }

.theme-btn, .ghost-btn, .primary-btn { padding: 0.75rem 1rem; background: var(--color-surface-2); color: var(--color-text); cursor: pointer; }

.primary-btn { background: var(--color-primary); color: white; border-color: transparent; }

.primary-btn:hover { background: var(--color-primary-hover); }

.panel-grid { display: grid; grid-template-columns: 320px 1fr; gap: var(--space-6); }

.panel { background: var(--color-surface-2); border: 1px solid rgba(0, 0, 0, 0.08); border-radius: var(--radius-xl); padding: var(--space-5); box-shadow: var(--shadow-sm); }

.panel h2 { font-size: var(--text-lg); margin: 0 0 var(--space-4); }

.field { display: grid; gap: 0.4rem; margin-bottom: var(--space-4); }

label { font-size: var(--text-sm); font-weight: 600; }

input, select { width: 100%; padding: 0.8rem 0.9rem; background: var(--color-surface); color: var(--color-text); }

.legend, .stats { display: grid; gap: 0.75rem; }

.legend-item, .stat { display: flex; align-items: center; gap: 0.75rem; color: var(--color-text-muted); font-size: var(--text-sm); }

.dot { width: 12px; height: 12px; border-radius: 999px; }

.content-head { display: flex; justify-content: space-between; align-items: flex-end; gap: var(--space-4); margin-bottom: var(--space-5); }

.day-tabs { display: flex; flex-wrap: wrap; gap: 0.5rem; }

.day-tab { padding: 0.65rem 0.85rem; border-radius: 999px; border: 1px solid rgba(0, 0, 0, 0.08); background: var(--color-surface-2); cursor: pointer; color: var(--color-text-muted); }

.day-tab.active { background: var(--color-primary-highlight); color: var(--color-primary); border-color: transparent; font-weight: 700; }

.shift-grid { display: grid; grid-template-columns: repeat(2, minmax(0px, 1fr)); gap: var(--space-5); }

.shift-card { background: var(--color-surface-2); border: 1px solid rgba(0, 0, 0, 0.08); border-radius: var(--radius-xl); padding: var(--space-5); box-shadow: var(--shadow-sm); }

.shift-card h3 { margin: 0 0 var(--space-1); font-size: var(--text-lg); }

.shift-card p { margin: 0 0 var(--space-4); color: var(--color-text-muted); font-size: var(--text-sm); }

.slot-list { display: grid; gap: 0.75rem; }

.slot-btn { width: 100%; text-align: left; padding: 0.95rem 1rem; background: var(--color-surface); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }

.slot-btn:hover { border-color: var(--color-primary); }

.slot-btn.full { opacity: 0.55; cursor: not-allowed; }

.slot-btn.mine { background: var(--color-primary-highlight); border-color: transparent; }

.slot-meta strong { display: block; font-size: var(--text-base); color: var(--color-text); }

.slot-meta span { font-size: var(--text-sm); color: var(--color-text-muted); }

.pill { padding: 0.35rem 0.65rem; border-radius: 999px; font-size: var(--text-xs); font-weight: 700; }

.available { background: rgb(217, 232, 208); color: rgb(45, 95, 16); }

.limited { background: rgb(239, 230, 200); color: rgb(124, 91, 0); }

.fullpill { background: rgb(231, 211, 222); color: rgb(125, 30, 94); }

.minepill { background: rgb(206, 220, 216); color: rgb(12, 78, 84); }

.table-wrap { margin-top: var(--space-6); overflow: auto; }

table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }

th, td { padding: 0.8rem; border-bottom: 1px solid rgba(0, 0, 0, 0.08); text-align: left; }

th { color: var(--color-text-muted); font-weight: 600; }

.empty { color: var(--color-text-faint); font-size: var(--text-sm); }

.inline-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.notice { margin-top: var(--space-4); padding: 0.9rem 1rem; border-radius: var(--radius-md); background: var(--color-surface); color: var(--color-text-muted); font-size: var(--text-sm); }

@media (max-width: 960px) {
  .panel-grid, .shift-grid { grid-template-columns: 1fr; }
  .content-head, .topbar { align-items: flex-start; flex-direction: column; }
  .wrap { padding: var(--space-4); }
}
